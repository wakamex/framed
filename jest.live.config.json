{
  "roots": ["test"],
  "testMatch": ["**/test/**/*live.test.js"],
  "testPathIgnorePatterns": ["/node_modules/"],
  "moduleNameMapper": {
    "@ledgerhq/cryptoassets/data/eip712": "@ledgerhq/cryptoassets/lib/data/eip712.js",
    "@ledgerhq/cryptoassets/data/erc20-signatures": "@ledgerhq/cryptoassets/lib/data/erc20-signatures.js",
    "\\.svg$": "<rootDir>/test/jest.svg.js"
  },
  "testTimeout": 30000,
  "fakeTimers": {
    "enableGlobally": false
  },
  "clearMocks": true,
  "setupFiles": ["<rootDir>/test/setupGlobals.js"],
  "setupFilesAfterEnv": ["<rootDir>/test/toMatchPath.js"]
}
